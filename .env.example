# Shopify Storefront API (lectura de productos/precios)
SHOPIFY_EU_DOMAIN=tu-tienda-eu.myshopify.com
SHOPIFY_EU_STOREFRONT_TOKEN=
SHOPIFY_UK_DOMAIN=
SHOPIFY_UK_STOREFRONT_TOKEN=

# Shopify Admin API (alta de clientes desde el popup/newsletter) — scope write_customers
SHOPIFY_EU_ADMIN_TOKEN=

# Resend (email de bienvenida con el código)
RESEND_API_KEY=
# Remitente verificado en Resend (dominio con SPF/DKIM ok). Ej: "Natura Esencials <hola@send.naturaesencials.com>"
RESEND_FROM=
# Código de descuento de bienvenida (reutilizable, 10%)
WELCOME_DISCOUNT_CODE=0KBYV7ANYCG1
